{
  "name": "fivucsas-admin-dashboard",
  "version": "1.0.0",
  "type": "module",
  "description": "FIVUCSAS Admin Dashboard - Face and Identity Verification Platform",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 45",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "build:analyze": "tsc && vite build --mode analyze",
    "build:adapter": "vite build --config vite.adapter.config.ts",
    "build:verify": "vite build --config vite.verify.config.ts",
    "dev:verify": "vite dev --config vite.verify.config.ts",
    "build:sdk": "vite build --config vite.sdk.config.ts"
  },
  "dependencies": {
    "@emotion/react": "^11.13.0",
    "@emotion/styled": "^11.13.0",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/poppins": "^5.2.7",
    "@hookform/resolvers": "^3.9.0",
    "@mediapipe/tasks-vision": "^0.10.18",
    "@mui/icons-material": "^5.16.0",
    "@mui/material": "^5.16.0",
    "@reduxjs/toolkit": "^2.2.0",
    "@tensorflow-models/blazeface": "^0.1.0",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0",
    "axios": "^1.7.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "date-fns": "^3.6.0",
    "framer-motion": "^12.31.0",
    "i18next": "^25.8.12",
    "i18next-browser-languagedetector": "^8.2.1",
    "inversify": "^7.10.4",
    "jwt-decode": "^4.0.0",
    "lottie-react": "^2.4.1",
    "notistack": "^3.0.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.0",
    "react-i18next": "^16.5.4",
    "react-redux": "^9.1.0",
    "react-router-dom": "^6.26.0",
    "recharts": "^2.12.0",
    "redux-persist": "^6.0.0",
    "reflect-metadata": "^0.2.2",
    "socket.io-client": "^4.7.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/aria-query": "^5.0.4",
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__template": "^7.4.4",
    "@types/babel__traverse": "^7.28.0",
    "@types/estree": "^1.0.8",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.13.1",
    "@typescript-eslint/parser": "^7.13.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^2.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "jsdom": "^27.2.0",
    "typescript": "^5.5.3",
