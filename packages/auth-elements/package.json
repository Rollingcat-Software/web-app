{
  "name": "@fivucsas/auth-elements",
  "version": "0.1.0",
  "description": "The <fivucsas-verify> Web Component — a framework-agnostic custom element wrapping the FIVUCSAS biometric authentication flow.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "unpkg": "./dist/index.global.js",
  "jsdelivr": "./dist/index.global.js",
  "types": "./dist/elements.d.ts",
  "exports": {
    ".": {
      "types": "./dist/elements.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/index.mjs",
    "./dist/index.cjs",
    "./dist/index.global.js"
  ],
  "keywords": [
    "fivucsas",
    "web-components",
    "custom-elements",
    "oidc",
    "authentication",
    "biometric",
    "mfa",
    "fivucsas-verify"
  ],
  "license": "MIT",
  "author": "FIVUCSAS Team",
  "homepage": "https://verify.fivucsas.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rollingcat-Software/web-app.git",
    "directory": "packages/auth-elements"
  },
  "bugs": {
    "url": "https://github.com/Rollingcat-Software/web-app/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "peerDependencies": {
    "@fivucsas/auth-js": "^0.1.0"
  },
  "peerDependenciesMeta": {
    "@fivucsas/auth-js": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  }
}
