# SPA Routing
RewriteEngine On
RewriteBase /
RewriteRule ^index\.html$ - [L]
RewriteRule ^auth-test/ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]

# Cache Control
<IfModule mod_headers.c>
  # HTML - always revalidate
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # JS/CSS with hash in filename - cache aggressively
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# Security Headers
<IfModule mod_headers.c>
    # Content Security Policy (frame-ancestors MUST be in HTTP header, not meta tag)
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-eval' 'wasm-unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://auth.rollingcatsoftware.com https://bpa-fivucsas.rollingcatsoftware.com https://cdn.jsdelivr.net https://storage.googleapis.com https://api.qrserver.com; media-src 'self' blob:; worker-src 'self' blob:; frame-ancestors 'self' https://ica-fivucsas.rollingcatsoftware.com https://fivucsas.rollingcatsoftware.com; base-uri 'self'; form-action 'self';"

    # Prevent clickjacking
    Header set X-Frame-Options "SAMEORIGIN"

    # Prevent MIME type sniffing
    Header set X-Content-Type-Options "nosniff"

    # XSS Protection
    Header set X-XSS-Protection "1; mode=block"

    # Referrer Policy
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # Permissions Policy
    Header set Permissions-Policy "camera=(self), microphone=(self), geolocation=()"

    # Strict Transport Security (HTTPS only)
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>
