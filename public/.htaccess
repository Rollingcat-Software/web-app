# SPA Routing
RewriteEngine On
RewriteBase /
RewriteRule ^index\.html$ - [L]
RewriteRule ^auth-test/ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]

# Cache Control
<IfModule mod_headers.c>
  # HTML - always revalidate
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # JS/CSS with hash in filename - cache aggressively
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# Security Headers
<IfModule mod_headers.c>
    # Content Security Policy (frame-ancestors MUST be in HTTP header, not meta tag)
    #
    # Per-route CSP (FE-H3, tightens the earlier B9 work):
    #   - DEFAULT (dashboard / admin routes): strict `script-src 'self'` with
    #     NO 'unsafe-eval' and NO 'wasm-unsafe-eval'. Dashboard pages don't run
    #     ONNX / TFJS — only /verify, /enroll, /biometric do.
    #   - /verify*, /enroll*, /biometric*: relaxed CSP that keeps
    #     'unsafe-eval' + 'wasm-unsafe-eval' (onnxruntime-web + tfjs need them).
    #   - /login: frame-ancestors 'none' (top-level OIDC sign-in page must NEVER
    #     be framable — clickjacking defense; JS frame-bust in HostedLoginApp.tsx
    #     for defense-in-depth).
    #
    # Apache evaluates <If> blocks after the default Header set and the LAST
    # matching Header set wins, so the <If> overrides below replace the default.
    #
    # Hostinger quoting rule (per project memory): the Apache <If> directive
    # uses a double-quoted regex delimiter, but the Header set VALUE uses
    # double-quotes with bare 'self' tokens inside (no backslash escapes) —
    # Hostinger's mod_headers leaks literal \" sequences otherwise. This is
    # the same quoting style as the earlier B9 rule that is known to ship
    # clean headers.
    # Default CSP applies to every non-listed path, including the SPA root `/`.
    # The web-app is a biometric platform: `/biometric-puzzles`, `/biometric-tools`,
    # and other routes lazy-load MediaPipe / TFJS WASM. React Router does NOT
    # reload the HTML between routes, so the CSP from the initial `/` response
    # is what the browser enforces for every subsequent client-side navigation.
    # Keeping the default strict meant any user who landed on `/` first could
    # never load biometric WASM — reported as:
    #   "WebAssembly.instantiate(): ... 'unsafe-eval' is not an allowed source"
    # Unify with the biometric routes below.
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-eval' 'wasm-unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://api.fivucsas.com https://bio.fivucsas.com https://cdn.jsdelivr.net https://storage.googleapis.com https://api.qrserver.com https://tfhub.dev; media-src 'self' blob:; worker-src 'self' blob:; frame-ancestors 'self' https://*.fivucsas.com; base-uri 'self'; form-action 'self';"

    # Biometric / verification / enrollment routes need 'unsafe-eval' +
    # 'wasm-unsafe-eval' for onnxruntime-web and @tensorflow/tfjs.
    <If "%{REQUEST_URI} =~ m#^/(verify|enroll|biometric)#">
        Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-eval' 'wasm-unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://api.fivucsas.com https://bio.fivucsas.com https://cdn.jsdelivr.net https://storage.googleapis.com https://api.qrserver.com https://tfhub.dev; media-src 'self' blob:; worker-src 'self' blob:; frame-ancestors 'self' https://*.fivucsas.com; base-uri 'self'; form-action 'self';"
    </If>

    # Hosted login (/login): runs the full MFA flow including face capture
    # (BlazeFace/TFJS + MediaPipe fallback), so script-src needs 'unsafe-eval'
    # and 'wasm-unsafe-eval'. frame-ancestors stays 'none' — top-level OIDC
    # sign-in page must never be framable (clickjacking defense).
    <If "%{REQUEST_URI} =~ m#^/login#">
        Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-eval' 'wasm-unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://api.fivucsas.com https://bio.fivucsas.com https://cdn.jsdelivr.net https://storage.googleapis.com https://api.qrserver.com https://tfhub.dev; media-src 'self' blob:; worker-src 'self' blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'self';"
    </If>

    # X-Frame-Options removed: CSP frame-ancestors supersedes it and supports wildcard subdomains
    # X-Frame-Options only supports DENY/SAMEORIGIN (no multi-origin), so frame-ancestors is the standard

    # Prevent MIME type sniffing
    Header set X-Content-Type-Options "nosniff"

    # XSS Protection
    Header set X-XSS-Protection "1; mode=block"

    # Referrer Policy
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # Permissions Policy
    Header set Permissions-Policy "camera=(self), microphone=(self), geolocation=()"

    # Strict Transport Security (HTTPS only)
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Per-route X-Robots-Tag (addresses Copilot #27 concern):
    # The SPA serves the same index.html for every route, so the <meta name="robots">
    # inside that file applies to authenticated routes too — even though robots.txt
    # disallows crawling them, Google can still "index without crawling" and list
    # them as discovered URLs. An HTTP-level X-Robots-Tag overrides the meta for
    # those paths and is the standard defence-in-depth signal.
    <If "%{REQUEST_URI} =~ m#^/(users|tenants|roles|auth-flows|auth-sessions|devices|enrollments|enrollment|user-enrollment|biometric-tools|card-detection|face-search|voice-search|nfc-enrollment|audit-logs|analytics|verification-flows|verification-dashboard|verification-sessions|guests|my-profile|settings|models)#">
        Header set X-Robots-Tag "noindex, nofollow"
    </If>
</IfModule>
